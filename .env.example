# ---- Postgres (pgvector) ----
POSTGRES_USER=ragdesk
POSTGRES_PASSWORD=ragdesk
POSTGRES_DB=ragdesk

# ---- API (Go core service) ----
PORT=8080
DATABASE_URL=postgres://ragdesk:ragdesk@localhost:5432/ragdesk?sslmode=disable
REDIS_URL=redis://localhost:6379/0
AI_SERVICE_URL=http://localhost:8000
RAGDESK_ENV=development

# ---- AI (Python FastAPI service) ----
# Provider-agnostic LLM: defaults to a local, free Ollama instance.
# Swap to a free-tier hosted provider (Gemini/Groq) or Claude later.
OLLAMA_BASE_URL=http://localhost:11434
